issn = {18790291},
journal = {Marine Environmental Research},
keywords = {Canyons,Connectivity,Currents,Daily Vertical Migration,Fertilization,Marine Spatial Planning,Zooplankton,primary production,sealevelmonitorreport,zeespiegelmonitor},
mendeley-tags = {primary production,sealevelmonitorreport,zeespiegelmonitor},
