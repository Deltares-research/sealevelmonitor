journal = {Journal of environmental management},
keywords = {Conservation of Natural Resources,Conservation of Natural Resources: methods,Ecosystem,Environmental Monitoring,Marine Biology,Models, Theoretical,Oceans and Seas,Waddenzee,sealevelmonitorreport,waddenzee,zeespiegelmonitor},
mendeley-tags = {Waddenzee,sealevelmonitorreport,waddenzee,zeespiegelmonitor},
month = {nov},
pages = {135--45},
pmid = {24076513},
publisher = {Elsevier Ltd},
title = {{Typology and indicators of ecosystem services for marine spatial planning and management.}},
url = {http://www.ncbi.nlm.nih.gov/pubmed/24076513},
volume = {130},
year = {2013}
}
