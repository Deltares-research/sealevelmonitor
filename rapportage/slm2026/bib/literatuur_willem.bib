file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Cinnirella et al. - 2012 - A multidisciplinary Spatial Data Infrastructure for the Mediterranean to support the implementation of the Ma.pdf:pdf},
issn = {1725-0463},
journal = {International Journal of Spatial Data Infrastructure Research},
keywords = {Chemical pollution,DPSIR,EUROGEOSS,Ecosystem Approach,Environmental Management,Marine Strategy Framework Directive,Spatial Data Infrastructures,Web Services,sealevelmonitorreport,zeespiegelmonitor},
mendeley-tags = {sealevelmonitorreport,zeespiegelmonitor},
pages = {323--351},
title = {{A multidisciplinary Spatial Data Infrastructure for the Mediterranean to support the implementation of the Marine Strategy Framework Directive }},
volume = {7},
year = {2012}
}
