@techreport{Langenberg2008,
abstract = {This study was carried out to obtain an overview of the main indicator frameworks with their respective types of indicators used or developed for the monitoring of Marine ecosystems in the Netherlands. We identified a total of 199 indicators belonging to 8 frame works and ranked (scored) them using a qualitative analyses based on the “ICES criteria for a good indicators” used for technical evaluation. All identified indicators were related (linked) to all GES qualitative descriptors for determining Good Environmental Status (Annex 1 of the MSFD–Directive 2008/56/EC). Those GES descriptors with a limited number of relevant indicators were identified for further attention (GES descriptors with ‘information gaps'). A maximum of two high ranked indicators of the least covered GES descriptors were identified. All combined this led to a shortlist of 11 indicators that were analysed for their applicability, scientific soundness, practicality and the probable costs involved with future implementation in GES monitoring. All 11 indicators showed to be of high ecological relevance. The establishment of consistent indicator reference target or limit levels seemed intricate mostly due to lack of or insufficient quality of the quantitative basis for setting such levels. Another underlying difficulty is the insufficient understanding of the complex correlations between pressure and impact in time and space. This hampers especially the full implementation and further development of those indicators meant for the monitoring of impacted biota (e.g., benthos, plankton and seals) and may easily lead to a descriptive and costly monitoring that only gradually in time may allow one to correlate system responses to other external events or vice versa and derive cause-effect relationships. The pressure indicators that monitor physical and chemical phenomena scored higher on the technical evaluation, where unambiguous, and reference as well as limit levels may be constructed and set relatively easily. The time frames for implementation and outcome assessment may furthermore be short and costs are relatively low. It is recommended that a balanced set of indicators may be needed for monitoring the GES of the North Sea ecosystem in the context of conservation, protection, and sustainable use. For successful implementation, some indicators of the set should be scientifically specific and designed to further unravel the ecosystem responses to variable human induced impacts, while other indicators, with less explanatory power, will have to monitor anthropogenic drivers and pressures. The set of indicators must be able to address the different objectives set by ecological, social and economic structures.},
address = {Delft},
author = {Langenberg, V T and Troost, T A},
file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Langenberg, Troost - 2008 - Overview of indicators for Good Environmental Status Overview of indicators for Good Environmental Status.pdf:pdf},
institution = {Deltares},
keywords = {Eastern Scheldt,Grevelingen Oosterschelde,Oosterschelde,Waddenzee,Westerschelde,primary production,sealevelmonitorreport,veersemeer,waddenzee,zeespiegelmonitor},
mendeley-tags = {Eastern Scheldt,Grevelingen Oosterschelde,Oosterschelde,Waddenzee,Westerschelde,primary production,sealevelmonitorreport,veersemeer,waddenzee,zeespiegelmonitor},
pages = {58},
title = {{Overview of indicators for Good Environmental Status Overview of indicators for Good Environmental Status}},
year = {2008}
}
