number = {2018},
pages = {24},
title = {{Conflict Fiche 5 - Offshore wind and commercial fisheries}},
url = {https://www.msp-platform.eu/sites/default/files/5{\_}offshore{\_}wind{\_}fisheries{\_}1.pdf},
year = {2019}
}
