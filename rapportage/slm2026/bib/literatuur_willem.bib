journal = {International Journal of Environmental Research},
keywords = {Chlorophyll a,Eutrophication,Nutrients,Pollution,Sewage,sealevelmonitorreport,zeespiegelmonitor},
mendeley-tags = {sealevelmonitorreport,zeespiegelmonitor},
number = {4},
