@article{Brouwer2016,
abstract = {Despite increasing attention paid to the value of marine resources, in particular marine protected areas (MPAs), their economic valuation focuses mainly on use values of ecosystem services such as fishery and tourism. Furthermore, most MPA related studies are carried out for coastal ecosystems, especially tropical coral reefs. The valuation of remote marine ecosystems is rare. The main objective of this paper is to estimate public willingness to pay (WTP) for alternative management regimes of a network of offshore MPAs in the North Sea under the Marine Strategy Framework Directive (MSFD). In a baseline valuation study carried out just before the adoption of the MSFD, beach visitors and a random sample of coastal and non-coastal residents were asked for their preferences for two alternative management options of three remote, ecologically sensitive areas with multiple use conflicts. Despite the lack of public awareness and familiarity with the offshore marine areas, a majority of 70{\%} is willing to pay extra tax for their protection. Using a conservative value elicitation procedure, Dutch households are willing to pay on average maximum 0.25{\%} of their annual disposable income to ban access and economic use. This serves as an indicator of what a network of remote MPAs in the MSFD is allowed to cost according to the Dutch tax payer.},
author = {Brouwer, R. and Brouwer, S. and Eleveld, M.a. and Verbraak, M. and a.J. Wagtendonk and van der Woerd, H.J.},
doi = {10.1016/j.marpol.2016.03.001},
file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Brouwer et al. - 2016 - Public willingness to pay for alternative management regimes of remote marine protected areas in the North Sea.pdf:pdf},
issn = {0308597X},
journal = {Marine Policy},
keywords = {Contingent valuation,Marine Strategy Framework Directive,Marine biodiversity,Marine protected areas,Non-use value,Public willingness to pay,sealevelmonitorreport,zeespiegelmonitor},
mendeley-tags = {sealevelmonitorreport,zeespiegelmonitor},
pages = {195--204},
publisher = {Elsevier},
title = {{Public willingness to pay for alternative management regimes of remote marine protected areas in the North Sea}},
url = {http://www.sciencedirect.com/science/article/pii/S0308597X16300823},
volume = {68},
year = {2016}
}
