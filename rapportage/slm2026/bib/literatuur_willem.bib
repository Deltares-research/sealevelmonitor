file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Houston - 2021 - Sea-level acceleration Analysis of the world's high-quality tide gauges.pdf:pdf},
issn = {15515036},
