month = {oct},
number = {10},
pages = {1102--1106},
pmid = {15344936},
title = {{Molecular evidence that plastids in the toxin-producing dinoflagellate genus Dinophysis originate from the free-living cryptophyte Teleaulax amphioxeia}},
