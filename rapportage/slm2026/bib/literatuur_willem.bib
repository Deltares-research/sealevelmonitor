mendeley-tags = {sealevelmonitorreport,zeespiegelmonitor},
month = {jun},
number = {6},
pages = {1169--82},
pmid = {21497856},
title = {{Inter- and intra-annual patterns of Ulva prolifera green tides in the Yellow Sea during 2007-2009, their origin and relationship to the expansion of coastal seaweed aquaculture in China.}},
