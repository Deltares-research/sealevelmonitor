file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Letters - 2013 - Unimodal size scaling of phytoplankton growth and the size dependence of nutrient uptake and use.pdf:pdf},
issn = {1461-0248},
journal = {Ecology letters},
keywords = {16,2013,371,379,carbon,ecology letters,growth rate,nitrogen,nitrogen maximum uptake rate,photosynthesis,phytoplankton,primary production,respiration,sealevelmonitorreport,size scaling,stoichiometry,zeespiegelmonitor},
mendeley-tags = {primary production,sealevelmonitorreport,zeespiegelmonitor},
