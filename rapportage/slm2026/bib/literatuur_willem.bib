@article{Timmerman2010,
abstract = {Water quality monitoring has developed over the past century from an unplanned, isolated activity into an important discipline in water management. This development also brought about a discontent between information users and information producers about the usefulness and usability of information, in literature often referred to as the data-rich-but-information-poor syndrome. This article aims to gain a better understanding of this issue by studying the developments over some five decades of Dutch national water quality monitoring, by analyzing four studies in which the role and use of information are discussed from different perspectives, and by relating this to what is considered in literature as useful information. The article concludes that a "water information gap" exists which is rooted in different mutual perceptions and expectations between the two groups on what useful information is, that can be overcome by improving the communication. Such communication should be based on willingness to understand and deal with different mindframes and should be based on a methodology that guides and structures the interactions.},
author = {Timmerman, Jos G. and Beinat, Euro and Termeer, Katrien and Cofino, Wim},
doi = {10.1007/s00267-010-9459-5},
file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Timmerman et al. - 2010 - Analyzing the data-rich-but-information-poor syndrome in dutch water management in historical perspective.pdf:pdf},
issn = {0364152X},
journal = {Environmental Management},
keywords = {Environmental information,Information needs,Science-policy interface,Waddenzee,Water-quality monitoring,sealevelmonitorreport,waddenzee,zeespiegelmonitor},
mendeley-tags = {Waddenzee,sealevelmonitorreport,waddenzee,zeespiegelmonitor},
number = {5},
pages = {1231--1242},
pmid = {20221829},
title = {{Analyzing the data-rich-but-information-poor syndrome in dutch water management in historical perspective}},
volume = {45},
year = {2010}
}
