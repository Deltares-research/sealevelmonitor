@article{Keogh2019,
abstract = {Although tide gauges are the primary source of data used to calculate multi-decadal- to century-scale rates of relative sea-level change, we question the usefulness of tide-gauge data in rapidly subsiding low-elevation coastal zones (LECZs). Tide gauges measure relative sea-level rise (RSLR) with respect to the base of associated benchmarks. Focusing on coastal Louisiana, the largest LECZ in the United States, we find that these benchmarks ({\textless}span classCombining double low line"inline-formula"{\textgreater}{\textless}i{\textgreater}n{\textless}/i{\textgreater}Combining double low line35{\textless}/span{\textgreater}) are anchored an average of 21.5{\&}thinsp;m below the land surface. Because at least 60{\&}thinsp;{\%} of subsidence occurs in the top 5{\&}thinsp;m of the sediment column in this area, tide gauges in coastal Louisiana do not capture the primary contributor to RSLR. Similarly, global navigation satellite system (GNSS) stations ({\textless}span classCombining double low line"inline-formula"{\textgreater}{\textless}i{\textgreater}n{\textless}/i{\textgreater}Combining double low line10{\textless}/span{\textgreater}) are anchored an average of {\textgreater}{\&}thinsp;14.3{\&}thinsp;m below the land surface and therefore also do not capture shallow subsidence. As a result, tide gauges and GNSS stations in coastal Louisiana, and likely in LECZs worldwide, systematically underestimate rates of RSLR as experienced at the land surface. We present an alternative approach that explicitly measures RSLR in LECZs with respect to the land surface and eliminates the need for tide-gauge data in this context. Shallow subsidence is measured by rod surface-elevation table-marker horizons (RSET-MHs) and added to measurements of deep subsidence from GNSS data, plus sea-level rise from satellite altimetry. We show that for an LECZ the size of coastal Louisiana (25{\&}thinsp;000-30{\&}thinsp;000{\&}thinsp;km{\textless}span classCombining double low line"inline-formula"{\textgreater}2){\textless}/span{\textgreater}, about 40 RSET-MH instruments suffice to collect useful data. Rates of RSLR obtained from this approach are substantially higher than rates as inferred from tide-gauge data. We therefore conclude that LECZs may be at higher risk of flooding within a shorter time horizon than previously assumed.},
author = {Keogh, Molly E. and T{\"{o}}rnqvist, Torbj{\"{o}}rn E.},
doi = {10.5194/os-15-61-2019},
file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Keogh, T{\"{o}}rnqvist - 2019 - Measuring rates of present-day relative sea-level rise in low-elevation coastal zones A critical evaluation.pdf:pdf},
issn = {18120792},
journal = {Ocean Science},
keywords = {sealevelmonitorreport},
mendeley-tags = {sealevelmonitorreport},
number = {1},
pages = {61--73},
title = {{Measuring rates of present-day relative sea-level rise in low-elevation coastal zones: A critical evaluation}},
volume = {15},
year = {2019}
}
